# Prisma / app — database "reinova" on your local server (create empty DB "reinova" in pgAdmin if needed).
# Password below is URL-encoded: "test 123456" → test%20123456 (space = %20). If your password has no space, use e.g. test123456.
DATABASE_URL="postgresql://postgres:test%20123456@localhost:5443/reinova?schema=public"

# pgAdmin → Register → Server:
#   Host name: localhost
#   Port:      5443
#   Maintenance database: postgres
#   Username: postgres
#   Password: test 123456
# Then create database "reinova" (if not exists): Databases → Create → Database → Name: reinova
PORT=3000
# Comma-separated browser origins allowed to call the API (credentials). Add ngrok URL when you tunnel the Angular dev server.
CORS_ORIGIN=http://localhost:4200

# Base URL of the web app (links in emails: email verification). No trailing slash.
WEB_APP_URL=http://localhost:4200

# Activation links expire after this many hours (default 48).
EMAIL_VERIFICATION_EXPIRES_HOURS=48

# JWT access token (OAuth2-style Bearer). Use a long random string in production.
JWT_SECRET=change-me-to-a-long-random-secret
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_DAYS=7

# SendGrid (transactional email). Create an API key at https://app.sendgrid.com/settings/api_keys
# Sender must be verified in SendGrid (Single Sender or Domain Authentication).
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=noreply@your-verified-domain.com
# Optional display name: "Reinova" -> Reinova <noreply@...>
SENDGRID_FROM_NAME=

# --- Tavus / video (optional; code defaults apply if empty) ---
TAVUS_API_KEY=
TAVUS_BASE_URL=
TAVUS_POLL_INTERVAL_MS=
TAVUS_POLL_MAX_MS=

# --- FFmpeg (optional; default: ffmpeg on PATH) ---
FFMPEG_PATH=

# --- HTTP client timeout for long requests (ms; default 600000) ---
HTTP_TIMEOUT_MS=
